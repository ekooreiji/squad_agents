graph TB
    subgraph "AWS Global"
        ROUTE53([Route 53])
        CLOUDFRONT([CloudFront])
        ACM([ACM Certificates])
    end

    subgraph "AWS VPC"
        ALB([Application LB])
        subgraph "Public Subnet"
            NGINX([Nginx EC2])
        end
        subgraph "Private Subnet App"
            FLASK([Flask EC2])
            FASTAPI([FastAPI ECS])
        end
        subgraph "Private Subnet Data"
            RDS[(RDS PostgreSQL)]
            ELASTI[(ElastiCache)]
        end
    end

    subgraph "AWS Services"
        S3([S3 Bucket])
        SES([SES Email])
        SQS{{(SQS Queue)}}
    end

    ROUTE53 --> CLOUDFRONT
    CLOUDFRONT --> ALB
    ALB --> NGINX
    NGINX --> FLASK
    NGINX --> FASTAPI
    FLASK --> RDS
    FLASK --> ELASTI
    FASTAPI --> RDS
    FASTAPI --> ELASTI
    FASTAPI --> SQS
    FLASK --> S3
    FLASK --> SES

    style AWS Global fill:#e3f2fd,stroke:#1976d2
    style VPC fill:#e8f5e9,stroke:#388e3c
    style Services fill:#f3e5f5,stroke:#7b1fa2